# ═══════════════════════════════════════════════════════════════
#  Mithai 2.0 — Environment Variables
# ═══════════════════════════════════════════════════════════════
#
#  SETUP:
#    1. Copy this file → .env.local
#    2. Fill in values marked with <...>
#    3. Never commit .env.local to git
#
# ═══════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────
# Local: mongodb://localhost:27017/mithai2
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/mithai2
MONGODB_URI=mongodb://localhost:27017/mithai2

# ─── NextAuth.js ──────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=<generate-a-random-secret>
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth (optional) ─────────────────────────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Razorpay (optional) ─────────────────────────────────────
# https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ─── Cloudinary (optional) ───────────────────────────────────
# https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Admin Seed ───────────────────────────────────────────────
# Used by `npm run seed` to create admin account
ADMIN_EMAIL=fazilashariff786@gmail.com
ADMIN_PASSWORD=Admin@123456
